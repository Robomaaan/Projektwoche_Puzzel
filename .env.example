# Local backend/frontend
BACKEND_PORT=8000
PORT=8000
API_BASE_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api
ALLOWED_ORIGINS=http://localhost:5173,https://projektwoche-puzzel.vercel.app
CROSS_SITE_COOKIES=false
SESSION_SECRET=change-me-in-real-env
UPLOAD_MAX_MB=10

# Local Prisma dev fallback (schema currently uses SQLite locally)
DATABASE_URL=file:../data/puzzlestudio.sqlite

# Supabase Storage adapter (optional, server-side only; keep service role out of frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
SUPABASE_STORAGE_BUCKET=puzzle-assets

# Supabase/Postgres deployment target notes
# Use a Supabase Postgres connection string only in backend/serverless environments.
# Do not expose database URLs or service-role keys to Vite/browser code.
POSTGRES_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
